# Copie este arquivo para .env e preencha (nunca commite .env com senhas reais).
# PowerShell: Copy-Item env.example .env

# Senha do usuário não-root que o WordPress usa no MariaDB
WORDPRESS_DB_PASSWORD=uma_senha_forte_aqui

# Senha do root do MariaDB (administração do banco; use só em dev)
MARIADB_ROOT_PASSWORD=outra_senha_forte_aqui

# Opcional: porta no seu PC (padrão 8080)
# WP_PORT=8080

# Opcional: locale do core na primeira subida
# WORDPRESS_LOCALE=pt_BR

# WP-CLI (serviço wpcli no docker-compose): instalar plugins — ver PLUGINS-WORDPRESS.txt
# docker compose --profile wpcli run --rm wpcli wp plugin list
